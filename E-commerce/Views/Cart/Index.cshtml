@model List<SimpleEcommerce.Models.CartItem>

@{
    ViewData["Title"] = "Корзина - AiMarket";
    decimal totalAmount = ViewBag.TotalAmount ?? 0m;
    decimal userBalance = ViewBag.UserBalance ?? 0m;
    bool hasEnoughBalance = ViewBag.HasEnoughBalance ?? false;
}

@Html.AntiForgeryToken()

<div class="container page-cart mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="cart-title">Корзина</h1>
        @if (Model.Count > 0)
        {
            <button class="btn btn-outline-danger btn-sm" id="clearCartBtn">
                <i class="bi bi-trash me-1"></i>Очистить корзину
            </button>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x" style="font-size: 4rem; color: #dee2e6;"></i>
            <h4 class="mt-3 mb-2">Корзина пуста</h4>
            <p class="text-muted mb-4">Добавьте товары из каталога</p>
            <a href="@Url.Action("Index", "Product")" class="btn btn-primary">
                <i class="bi bi-arrow-left me-2"></i>Перейти в каталог
            </a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="cart-items">
                    @foreach (var item in Model)
                    {
                        <div class="cart-item card mb-3" data-product-id="@item.ProductId">
                            <div class="card-body">
                                <div class="row align-items-center">
                                    <div class="col-md-2 col-4">
                                        <img src="@item.ImageUrl" alt="@item.Name" class="img-fluid rounded cart-item-image">
                                    </div>
                                    <div class="col-md-4 col-8">
                                        <h6 class="cart-item-name mb-1">@item.Name</h6>
                                        <small class="text-muted">
                                            <i class="bi bi-shop me-1"></i>@(item.StoreName ?? "Магазин")
                                        </small>
                                    </div>
                                    <div class="col-md-2 col-4 mt-3 mt-md-0">
                                        <div class="cart-item-price">
                                            <span class="fw-bold text-primary">@item.Price.ToString("N0")</span>
                                            <span class="text-muted">₽</span>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-4 mt-3 mt-md-0">
                                        <div class="input-group input-group-sm">
                                            <button class="btn btn-outline-secondary cart-quantity-decrease" type="button" data-product-id="@item.ProductId">-</button>
                                            <input type="number" class="form-control text-center cart-quantity-input" value="@item.Quantity" min="1" data-product-id="@item.ProductId" readonly>
                                            <button class="btn btn-outline-secondary cart-quantity-increase" type="button" data-product-id="@item.ProductId">+</button>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-4 mt-3 mt-md-0 text-end">
                                        <div class="cart-item-total">
                                            <span class="fw-bold">@item.Total.ToString("N0")</span>
                                            <span class="text-muted">₽</span>
                                        </div>
                                        <button class="btn btn-link text-danger p-0 mt-1 cart-item-remove" data-product-id="@item.ProductId" title="Удалить">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-4">
                <div class="cart-summary card sticky-top" style="top: 100px;">
                    <div class="card-body">
                        <h5 class="card-title mb-4">Итого</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Товаров:</span>
                            <span class="fw-semibold">@Model.Sum(i => i.Quantity)</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Сумма:</span>
                            <span class="fw-bold fs-5 text-primary">@totalAmount.ToString("N0") ₽</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 pb-3 border-bottom">
                            <span class="text-muted">Ваш баланс:</span>
                            <span class="fw-semibold">@userBalance.ToString("N0") ₽</span>
                        </div>
                        @if (hasEnoughBalance)
                        {
                            <button class="btn btn-primary btn-lg w-100 mb-2" id="checkoutBtn">
                                <i class="bi bi-bag-check me-2"></i>Оформить заказ
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-lg w-100 mb-2" disabled>
                                <i class="bi bi-exclamation-circle me-2"></i>Недостаточно средств
                            </button>
                            <a href="@Url.Action("Profile", "Account", new { openTopUp = "1" })" class="btn btn-success btn-lg w-100">
                                <i class="bi bi-wallet2 me-2"></i>Пополнить баланс
                            </a>
                        }
                        <a href="@Url.Action("Index", "Product")" class="btn btn-outline-secondary w-100 mt-2">
                            <i class="bi bi-arrow-left me-2"></i>Продолжить покупки
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Увеличение количества
            $(document).on('click', '.cart-quantity-increase', function() {
                const productId = $(this).data('product-id');
                const input = $(`.cart-quantity-input[data-product-id="${productId}"]`);
                const currentValue = parseInt(input.val()) || 1;
                updateQuantity(productId, currentValue + 1);
            });

            // Уменьшение количества
            $(document).on('click', '.cart-quantity-decrease', function() {
                const productId = $(this).data('product-id');
                const input = $(`.cart-quantity-input[data-product-id="${productId}"]`);
                const currentValue = parseInt(input.val()) || 1;
                if (currentValue > 1) {
                    updateQuantity(productId, currentValue - 1);
                }
            });

            // Обновление количества
            function updateQuantity(productId, quantity) {
                $.ajax({
                    url: '@Url.Action("UpdateQuantity", "Cart")',
                    method: 'POST',
                    data: { productId, quantity },
                    success: function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert(response.message || 'Ошибка обновления количества');
                        }
                    },
                    error: function() {
                        alert('Ошибка при обновлении количества');
                    }
                });
            }

            // Удаление товара
            $(document).on('click', '.cart-item-remove', function() {
                if (!confirm('Удалить товар из корзины?')) return;
                
                const productId = $(this).data('product-id');
                $.ajax({
                    url: '@Url.Action("Remove", "Cart")',
                    method: 'POST',
                    data: { productId },
                    success: function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert(response.message || 'Ошибка удаления товара');
                        }
                    },
                    error: function() {
                        alert('Ошибка при удалении товара');
                    }
                });
            });

            // Очистка корзины
            $('#clearCartBtn').on('click', function() {
                if (!confirm('Очистить всю корзину?')) return;
                
                $.ajax({
                    url: '@Url.Action("Clear", "Cart")',
                    method: 'POST',
                    success: function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert(response.message || 'Ошибка очистки корзины');
                        }
                    },
                    error: function() {
                        alert('Ошибка при очистке корзины');
                    }
                });
            });

            // Оформление заказа
            $('#checkoutBtn').on('click', function() {
                if (!confirm('Оформить заказ на сумму @totalAmount.ToString("N0") ₽?')) return;
                
                const btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Оформление...');
                
                const token = $('input[name="__RequestVerificationToken"]').val();
                $.ajax({
                    url: '@Url.Action("Checkout", "Cart")',
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    },
                    data: {
                        __RequestVerificationToken: token
                    },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message || 'Заказ успешно оформлен!');
                            location.reload();
                        } else {
                            alert(response.message || 'Ошибка оформления заказа');
                            btn.prop('disabled', false).html('<i class="bi bi-bag-check me-2"></i>Оформить заказ');
                        }
                    },
                    error: function() {
                        alert('Ошибка при оформлении заказа');
                        btn.prop('disabled', false).html('<i class="bi bi-bag-check me-2"></i>Оформить заказ');
                    }
                });
            });
        });
    </script>
}
