@model List<SimpleEcommerce.Models.BlockedIp>
@{
    ViewData["Title"] = "Заблокированные IP";
    var blockedUsers = ViewBag.BlockedUsers as List<SimpleEcommerce.Models.User> ?? new List<SimpleEcommerce.Models.User>();
}

<div class="container mt-4">
    <div class="mb-4">
        <a href="@Url.Action("Index")" class="text-decoration-none">
            <i class="bi bi-arrow-left me-2"></i>Вернуться к списку пользователей
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">
            <i class="bi bi-ban text-danger me-2"></i>Заблокированные IP и пользователи
        </h1>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Добавить IP в блок-лист</h5>
        </div>
        <div class="card-body">
            @Html.AntiForgeryToken()
            <form method="post" action="@Url.Action("AddBlockedIp")" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">IP-адрес</label>
                    <input type="text" name="ip" class="form-control" placeholder="например 192.168.1.1" value="@ViewBag.PrefillIp" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Комментарий (необязательно)</label>
                    <input type="text" name="comment" class="form-control" placeholder="причина блокировки">
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-ban me-1"></i>Заблокировать
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 fw-semibold">Список заблокированных IP (@Model.Count)</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>IP</th>
                                <th>Комментарий</th>
                                <th>Дата добавления</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@item.Ip</td>
                                    <td>@(item.Comment ?? "—")</td>
                                    <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    <td class="text-end">
                                        <form method="post" action="@Url.Action("RemoveBlockedIp")" class="d-inline" onsubmit="return confirm('Разблокировать этот IP?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id">
                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                <i class="bi bi-unlock me-1"></i>Разблокировать
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted p-4 mb-0">Заблокированных IP пока нет.</p>
            }
        </div>
    </div>

    @if (blockedUsers.Any())
    {
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-header bg-white border-bottom">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-people me-2"></i>Пользователи с заблокированными IP (@blockedUsers.Count)
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">
                        <form method="get" action="@Url.Action("BlockedIps")" class="row g-3">
                            <div class="col-md-10">
                                <input type="text" class="form-control" name="search" value="@ViewBag.Search" 
                                       placeholder="Поиск по ID, Email, имени или фамилии...">
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-search me-2"></i>Найти
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Имя</th>
                                <th>Email</th>
                                <th>IP</th>
                                <th>Уровень</th>
                                <th>Баланс</th>
                                <th>Вывод</th>
                                <th>Заявки</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var userRequests = ViewBag.UserRequests as Dictionary<int, List<SimpleEcommerce.Models.PendingRequest>> ?? new Dictionary<int, List<SimpleEcommerce.Models.PendingRequest>>();
                            }
                            @foreach (var user in blockedUsers)
                            {
                                var userPendingRequests = userRequests.ContainsKey(user.Id) ? userRequests[user.Id] : new List<SimpleEcommerce.Models.PendingRequest>();
                                var topUpRequests = userPendingRequests.Where(p => p.Type == "TopUp").ToList();
                                var withdrawalRequests = userPendingRequests.Where(p => p.Type == "Withdrawal").ToList();
                                
                                <tr>
                                    <td class="fw-bold">@user.Id</td>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td>
                                        <span class="badge bg-danger">@(user.Ip ?? "—")</span>
                                    </td>
                                    <td>
                                        @{
                                            var levelTooltip = user.Level == 0
                                                ? "Уровень 0: доступен заработок за добавление объявлений в избранное."
                                                : "Уровень 1: добавление в избранное + выкуп товаров 1 и 2 ранга.";
                                        }
                                        <span class="badge bg-info" title="@levelTooltip">@user.Level</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-success fs-6">@user.Balance.ToString("N0") ₽</span>
                                    </td>
                                    <td>
                                        <span class="badge @(user.WithdrawalEnabled ? "bg-success" : "bg-secondary")">
                                            @(user.WithdrawalEnabled ? "Разрешен" : "Запрещен")
                                        </span>
                                    </td>
                                    <td>
                                        @if (topUpRequests.Any() || withdrawalRequests.Any())
                                        {
                                            <div class="d-flex flex-column gap-2">
                                                @if (topUpRequests.Any())
                                                {
                                                    @foreach (var topUp in topUpRequests)
                                                    {
                                                        <div class="d-flex align-items-center gap-2">
                                                            <span class="badge bg-info" title="Заявка на пополнение">
                                                                <i class="bi bi-arrow-down-circle me-1"></i>Пополнение: @topUp.Amount.ToString("N0") ₽
                                                            </span>
                                                            <button type="button" class="btn btn-sm btn-success quick-topup-btn" 
                                                                    data-user-id="@user.Id" 
                                                                    data-amount="@topUp.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                                    data-user-name="@user.FullName">
                                                                <i class="bi bi-check-circle me-1"></i>Пополнить
                                                            </button>
                                                            <button type="button" class="btn btn-sm btn-outline-danger reject-topup-btn" 
                                                                    data-user-id="@user.Id" 
                                                                    data-amount="@topUp.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                                    data-user-name="@user.FullName">
                                                                <i class="bi bi-x-circle me-1"></i>Отклонить
                                                            </button>
                                                        </div>
                                                    }
                                                }
                                                @if (withdrawalRequests.Any())
                                                {
                                                    @foreach (var withdrawal in withdrawalRequests)
                                                    {
                                                        <div class="d-flex align-items-center gap-2">
                                                            <span class="badge bg-warning" title="Заявка на вывод: @withdrawal.Bank, @withdrawal.CardOrPhone">
                                                                <i class="bi bi-arrow-up-circle me-1"></i>Вывод: @withdrawal.Amount.ToString("N0") ₽
                                                            </span>
                                                            <small class="text-muted">@withdrawal.Bank</small>
                                                            <button type="button" class="btn btn-sm btn-danger quick-withdrawal-btn" 
                                                                    data-user-id="@user.Id" 
                                                                    data-amount="@withdrawal.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                                    data-user-name="@user.FullName"
                                                                    data-bank="@withdrawal.Bank"
                                                                    data-card="@withdrawal.CardOrPhone">
                                                                <i class="bi bi-check-circle me-1"></i>Подтвердить
                                                            </button>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Нет активных заявок</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex gap-1 justify-content-end flex-wrap">
                                            <a href="@Url.Action("EditLevel", new { id = user.Id })" 
                                               class="btn btn-sm btn-outline-info">
                                                <i class="bi bi-star me-1"></i>Уровень
                                            </a>
                                            <a href="@Url.Action("EditBalance", new { id = user.Id })" 
                                               class="btn btn-sm btn-primary">
                                                <i class="bi bi-pencil me-1"></i>Баланс
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Обработка быстрого пополнения баланса
            document.querySelectorAll('.quick-topup-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    const userId = this.getAttribute('data-user-id');
                    const amount = parseFloat(this.getAttribute('data-amount'));
                    const userName = this.getAttribute('data-user-name');
                    
                    if (!confirm(`Пополнить баланс пользователя ${userName} на ${amount.toLocaleString('ru-RU')} ₽?`)) {
                        return;
                    }
                    
                    const originalText = this.innerHTML;
                    this.disabled = true;
                    this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Обработка...';
                    
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    
                    const formData = new URLSearchParams();
                    formData.append('userId', userId);
                    formData.append('amount', amount.toString());
                    if (token) {
                        formData.append('__RequestVerificationToken', token);
                    }
                    
                    fetch('@Url.Action("QuickTopUp", "Admin")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token || ''
                        },
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert(data.message);
                            location.reload();
                        } else {
                            alert(data.message || 'Произошла ошибка при пополнении баланса');
                            this.disabled = false;
                            this.innerHTML = originalText;
                        }
                    })
                    .catch(error => {
                        console.error('Ошибка:', error);
                        alert('Произошла ошибка при пополнении баланса');
                        this.disabled = false;
                        this.innerHTML = originalText;
                    });
                });
            });
            
            // Обработка отклонения заявки на пополнение
            document.querySelectorAll('.reject-topup-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    const userId = this.getAttribute('data-user-id');
                    const amount = parseFloat(this.getAttribute('data-amount'));
                    const userName = this.getAttribute('data-user-name');
                    
                    if (!confirm(`Отклонить заявку на пополнение от пользователя ${userName} на ${amount.toLocaleString('ru-RU')} ₽?`)) {
                        return;
                    }
                    
                    const originalText = this.innerHTML;
                    this.disabled = true;
                    this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>...';
                    
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const formData = new URLSearchParams();
                    formData.append('userId', userId);
                    formData.append('amount', amount.toString());
                    if (token) {
                        formData.append('__RequestVerificationToken', token);
                    }
                    
                    fetch('@Url.Action("RejectTopUp", "Admin")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token || ''
                        },
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert(data.message);
                            location.reload();
                        } else {
                            alert(data.message || 'Не удалось отклонить заявку');
                            this.disabled = false;
                            this.innerHTML = originalText;
                        }
                    })
                    .catch(error => {
                        console.error('Ошибка:', error);
                        alert('Произошла ошибка при отклонении заявки');
                        this.disabled = false;
                        this.innerHTML = originalText;
                    });
                });
            });
            
            // Обработка быстрого подтверждения вывода средств
            document.querySelectorAll('.quick-withdrawal-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    const userId = this.getAttribute('data-user-id');
                    const amount = parseFloat(this.getAttribute('data-amount'));
                    const userName = this.getAttribute('data-user-name');
                    const bank = this.getAttribute('data-bank');
                    const card = this.getAttribute('data-card');
                    
                    if (!confirm(`Подтвердить вывод средств пользователя ${userName} на сумму ${amount.toLocaleString('ru-RU')} ₽?\nБанк: ${bank}\nРеквизиты: ${card}`)) {
                        return;
                    }
                    
                    const originalText = this.innerHTML;
                    this.disabled = true;
                    this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Обработка...';
                    
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    
                    const formData = new URLSearchParams();
                    formData.append('userId', userId);
                    formData.append('amount', amount.toString());
                    if (token) {
                        formData.append('__RequestVerificationToken', token);
                    }
                    
                    fetch('@Url.Action("QuickWithdrawal", "Admin")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token || ''
                        },
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert(data.message);
                            location.reload();
                        } else {
                            alert(data.message || 'Произошла ошибка при подтверждении вывода');
                            this.disabled = false;
                            this.innerHTML = originalText;
                        }
                    })
                    .catch(error => {
                        console.error('Ошибка:', error);
                        alert('Произошла ошибка при подтверждении вывода');
                        this.disabled = false;
                        this.innerHTML = originalText;
                    });
                });
            });
        });
    </script>
}
