@model List<SimpleEcommerce.Models.BlockedIp>
@{
    ViewData["Title"] = "Заблокированные IP";
}

<div class="container mt-4">
    <div class="mb-4">
        <a href="@Url.Action("Index")" class="text-decoration-none">
            <i class="bi bi-arrow-left me-2"></i>Вернуться к списку пользователей
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">
            <i class="bi bi-ban text-danger me-2"></i>Заблокированные IP
        </h1>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Добавить IP в блок-лист</h5>
        </div>
        <div class="card-body">
            @Html.AntiForgeryToken()
            <form method="post" action="@Url.Action("AddBlockedIp")" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">IP-адрес</label>
                    <input type="text" name="ip" class="form-control" placeholder="например 192.168.1.1" value="@ViewBag.PrefillIp" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Комментарий (необязательно)</label>
                    <input type="text" name="comment" class="form-control" placeholder="причина блокировки">
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-ban me-1"></i>Заблокировать
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 fw-semibold">Список заблокированных IP (@Model.Count)</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>IP</th>
                                <th>Комментарий</th>
                                <th>Дата добавления</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@item.Ip</td>
                                    <td>@(item.Comment ?? "—")</td>
                                    <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    <td class="text-end">
                                        <form method="post" action="@Url.Action("RemoveBlockedIp")" class="d-inline" onsubmit="return confirm('Разблокировать этот IP?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id">
                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                <i class="bi bi-unlock me-1"></i>Разблокировать
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted p-4 mb-0">Заблокированных IP пока нет.</p>
            }
        </div>
    </div>
</div>
