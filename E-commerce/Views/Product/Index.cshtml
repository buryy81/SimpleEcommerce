@model List<SimpleEcommerce.Models.Product>

@{
    ViewData["Title"] = "Каталог товаров - AiMarket";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalProducts = ViewBag.TotalProducts ?? 0;
    var favoriteIds = ViewBag.FavoriteIds as List<int> ?? new List<int>();
}

<div class="container page-catalog mt-4">
    <div class="catalog-header">
        <h1 class="catalog-title">Каталог товаров</h1>
        <span class="catalog-count">Найдено товаров: @totalProducts</span>
    </div>

    <div class="row g-4 catalog-grid">
        @foreach (var product in Model)
        {
            <div class="col-6 col-lg-4 col-xl-3">
                <div class="product-card card h-100 shadow-sm border-0 position-relative">
                    <div class="product-image-wrapper position-relative overflow-hidden">
                        <img src="@product.ImageUrl" class="card-img-top product-image catalog-product-img" alt="@product.Name">
                        <div class="position-absolute top-0 end-0 m-2">
                            @{
                                var isFav = favoriteIds.Contains(product.Id);
                            }
                            <button class="btn btn-sm rounded-circle p-2 favorite-btn @(isFav ? "btn-primary active" : "btn-light")" title="@(isFav ? "Удалить из избранного" : "В избранное")" data-product-id="@product.Id">
                                <i class="bi @(isFav ? "bi-heart-fill" : "bi-heart")"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column catalog-card-body">
                        <div class="mb-1">
                            <small class="text-muted catalog-store">
                                <i class="bi bi-shop me-1"></i>@(product.StoreName ?? "Магазин")
                            </small>
                        </div>
                        <h6 class="card-title catalog-product-title">@product.Name</h6>
                        <p class="card-text text-muted catalog-product-desc">@(product.Description ?? "Описание товара")</p>
                        <div class="mt-auto">
                            <div class="catalog-price-block">
                                <div class="d-flex align-items-baseline">
                                    <span class="catalog-price fw-bold text-primary">@product.Price.ToString("N0")</span>
                                    <span class="text-muted ms-1 catalog-price-currency">₽</span>
                                </div>
                                <small class="text-success catalog-in-stock"><i class="bi bi-check-circle-fill"></i> В наличии</small>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-primary btn-sm flex-grow-1 add-to-cart-btn" data-product-id="@product.Id" data-product-name="@product.Name" data-product-price="@product.Price">
                                    <i class="bi bi-cart-plus me-1"></i>В корзину
                                </button>
                                <a href="@Url.Action("Details", new { id = product.Id })" class="btn btn-outline-primary btn-sm" title="Подробнее">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <nav aria-label="Навигация по страницам" class="catalog-pagination mt-5">
            <ul class="pagination justify-content-center">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { page = currentPage - 1 })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                }

                @{
                    int startPage = Math.Max(1, currentPage - 2);
                    int endPage = Math.Min(totalPages, currentPage + 2);
                    
                    if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { page = 1 })">1</a>
                        </li>
                        @if (startPage > 2)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                        }
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                        </li>
                    }

                    @if (endPage < totalPages)
                    {
                        @if (endPage < totalPages - 1)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { page = totalPages })">@totalPages</a>
                        </li>
                    }
                }

                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { page = currentPage + 1 })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        // Ждем полной загрузки DOM
        document.addEventListener('DOMContentLoaded', function() {
            'use strict';
            
            // Кнопки избранного на карточках товаров — запрос к серверу и обновление вида
            const favoriteButtons = document.querySelectorAll('.favorite-btn');
            favoriteButtons.forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var productId = parseInt(this.getAttribute('data-product-id'), 10);
                    if (!productId) return;
                    var icon = this.querySelector('i');
                    if (!icon) return;

                    fetch('@Url.Action("ToggleFavorite", "Product")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: 'productId=' + productId
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (data.redirect && data.url) {
                            window.location.href = data.url;
                            return;
                        }
                        if (!data.success) return;
                        if (data.inFavorites) {
                            btn.classList.add('active', 'btn-primary');
                            btn.classList.remove('btn-light');
                            icon.classList.remove('bi-heart');
                            icon.classList.add('bi-heart-fill');
                            btn.title = 'Удалить из избранного';
                        } else {
                            btn.classList.remove('active', 'btn-primary');
                            btn.classList.add('btn-light');
                            icon.classList.remove('bi-heart-fill');
                            icon.classList.add('bi-heart');
                            btn.title = 'В избранное';
                        }
                    });
                });
            });
        });
    </script>
}