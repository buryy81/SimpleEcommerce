@model List<SimpleEcommerce.Models.Product>

@{
    ViewData["Title"] = "Избранное - AiMarket";
    var favoriteIds = ViewBag.FavoriteIds as List<int> ?? new List<int>();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0">
            <i class="bi bi-heart-fill text-danger me-2"></i>Избранное
        </h1>
        <span class="text-muted">Товаров: @Model.Count</span>
    </div>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5 bg-light rounded">
            <i class="bi bi-heart display-4 text-muted"></i>
            <p class="mt-3 text-muted">В избранном пока ничего нет</p>
            <a href="@Url.Action("Index", "Product")" class="btn btn-primary mt-2">
                <i class="bi bi-grid me-2"></i>Перейти в каталог
            </a>
        </div>
    }
    else
    {
        <div class="row g-2 g-md-3" id="favorites-list">
            @foreach (var product in Model)
            {
                <div class="col-6 col-md-4 col-lg-3 col-xl-2" data-product-id="@product.Id">
                    <div class="product-card card h-100 shadow-sm border-0 position-relative favorites-card">
                        <div class="product-image-wrapper position-relative overflow-hidden">
                            <img src="@product.ImageUrl" class="card-img-top product-image" alt="@product.Name" style="height: 120px; object-fit: cover;">
                            <div class="position-absolute top-0 end-0 m-1">
                                <button class="btn btn-sm btn-primary rounded-circle p-1 favorite-btn active" title="Удалить из избранного" data-product-id="@product.Id">
                                    <i class="bi bi-heart-fill" style="font-size: 0.75rem;"></i>
                                </button>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column p-2">
                            <small class="text-muted d-block mb-1" style="font-size: 0.7rem;">
                                @(product.StoreName ?? "Магазин")
                            </small>
                            <h6 class="card-title fw-semibold mb-1 small" style="min-height: 2.2em; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.2;">
                                @product.Name
                            </h6>
                            <div class="d-flex align-items-baseline mb-1">
                                <span class="fw-bold text-primary" style="font-size: 0.95rem;">@product.Price.ToString("N0")</span>
                                <span class="text-muted ms-1" style="font-size: 0.75rem;">₽</span>
                            </div>
                            <a href="@Url.Action("Details", "Product", new { id = product.Id })"
                               class="btn btn-primary btn-sm w-100 mt-auto">
                                Купить
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.favorite-btn').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var productId = parseInt(this.getAttribute('data-product-id'), 10);
                    if (!productId) return;

                    fetch('@Url.Action("ToggleFavorite", "Product")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: 'productId=' + productId
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (data.success && !data.inFavorites) {
                            var col = document.querySelector('#favorites-list [data-product-id="' + productId + '"]');
                            if (col) col.remove();
                            var count = document.querySelectorAll('#favorites-list [data-product-id]').length;
                            document.querySelector('.text-muted').textContent = 'Товаров: ' + count;
                            if (count === 0) location.reload();
                        }
                    });
                });
            });
        });
    </script>
}
