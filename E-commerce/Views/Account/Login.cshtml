@{
    ViewData["Title"] = "Вход";
}

<div class="container page-auth">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card auth-card shadow-sm">
                <div class="card-body">
                    <div class="auth-icon-wrap auth-icon-login">
                        <i class="bi bi-person-circle"></i>
                    </div>
                    <h1 class="auth-title">Вход в личный кабинет</h1>
                    <p class="auth-subtitle">Введите email и пароль для входа</p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mb-4">@ViewBag.Error</div>
                    }

                    <form method="post">
                        @if (ViewBag.ReturnUrl != null)
                        {
                            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                        }
                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <div class="input-group-auth">
                                <i class="bi bi-envelope input-icon"></i>
                                <input type="email" class="form-control" id="email" name="email" value="" placeholder="example@mail.ru" required>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-label">Пароль</label>
                            <div class="input-group-auth">
                                <i class="bi bi-lock input-icon"></i>
                                <input type="password" class="form-control" id="password" name="password" value="" placeholder="••••••••" required>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-auth-primary btn-login">Войти</button>
                            <a href="@Url.Action("Register")" class="btn btn-auth-link">
                                Нет аккаунта? Регистрация
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
