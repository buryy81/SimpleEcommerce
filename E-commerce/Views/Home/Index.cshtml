@{
    ViewData["Title"] = "Главная - AiMarket";
}

<section class="home-promo">
    <div class="container">
        <div class="home-promo-inner">
            <a href="/Product" class="btn btn-light btn-lg home-promo-cta">
                <i class="bi bi-grid-3x3-gap me-2"></i>Смотреть каталог
            </a>
        </div>
    </div>
</section>

<div class="container home-page">
    <div class="home-categories">
        <div class="row g-3 g-md-4">
            <div class="col-6 col-md-3">
                <a href="/Product" class="home-category-card">
                    <span class="home-category-icon"><i class="bi bi-laptop"></i></span>
                    <span class="home-category-name">Ноутбуки</span>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a href="/Product" class="home-category-card">
                    <span class="home-category-icon"><i class="bi bi-phone"></i></span>
                    <span class="home-category-name">Смартфоны</span>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a href="/Product" class="home-category-card">
                    <span class="home-category-icon"><i class="bi bi-headphones"></i></span>
                    <span class="home-category-name">Аудио</span>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a href="/Product" class="home-category-card">
                    <span class="home-category-icon"><i class="bi bi-keyboard"></i></span>
                    <span class="home-category-name">Периферия</span>
                </a>
            </div>
        </div>
    </div>

    <div class="home-features">
        <div class="row g-0 text-center">
            <div class="col-md-4 home-feature">
                <i class="bi bi-truck"></i>
                <span>Удобная доставка</span>
            </div>
            <div class="col-md-4 home-feature">
                <i class="bi bi-shield-check"></i>
                <span>Гарантия</span>
            </div>
            <div class="col-md-4 home-feature">
                <i class="bi bi-credit-card"></i>
                <span>Удобная оплата</span>
            </div>
        </div>
    </div>
</div>
