@* Единые реквизиты для пополнения баланса (личный кабинет и страница товара) *@
<div class="card topup-requisites-card mb-4">
    <div class="card-header topup-requisites-header">
        <h6 class="mb-0"><i class="bi bi-credit-card-2-front me-2"></i>Реквизиты для перевода</h6>
    </div>
    <div class="card-body topup-requisites-body">
        <div class="mb-3">
            <label class="form-label text-muted small">Номер карты</label>
            <div class="input-group topup-requisites-input-group">
                <input type="text" class="form-control fw-semibold" value="2200 7020 4514 2242" id="topUpCardNumber" readonly>
                <button class="btn btn-outline-secondary btn-copy-requisites" type="button" id="copyTopUpCardBtn" title="Копировать">
                    <i class="bi bi-clipboard"></i>
                </button>
            </div>
        </div>
        <div class="mb-2">
            <label class="form-label text-muted small">Получатель</label>
            <p class="mb-0 fw-semibold text-dark">Тинькофф банк. ИП Яндараев Тарас Иванович</p>
        </div>
        <div>
            <label class="form-label text-muted small">Назначение платежа</label>
            <p class="mb-0 text-muted small">Пополнение баланса</p>
        </div>
    </div>
</div>
