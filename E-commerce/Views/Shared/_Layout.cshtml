<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AiMarket</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"/>
    <open-graph />
</head>
<body>
    <header class="main-header">
        <div class="top-header bg-primary text-white py-2">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-geo-alt-fill me-2"></i>
                            <span class="small">Москва</span>
                        </div>
                    </div>
                    <div class="col-md-6 text-end">
                        <span class="small">Официальная платформа</span>
                    </div>
                </div>
            </div>
        </div>
        
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary fs-1" href="/" style="font-size: 2rem; padding: 0.5rem 1rem;">
                    <i class="bi bi-bag-check-fill" style="font-size: 1.5rem;"></i> AiMarket
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link nav-link-with-icon fw-semibold d-flex flex-column align-items-center py-0 px-2" href="/">
                                <i class="bi bi-house-door fs-5 mb-1 nav-link-icon"></i>
                                <span class="small">Главная</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-with-icon fw-semibold d-flex flex-column align-items-center py-0 px-2" href="/Product">
                                <i class="bi bi-grid fs-5 mb-1 nav-link-icon"></i>
                                <span class="small">Каталог</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-with-icon fw-semibold d-flex flex-column align-items-center py-0 px-2" href="@Url.Action("Favorites", "Product")" title="Избранное">
                                <i class="bi bi-heart fs-5 mb-1 nav-link-icon"></i>
                                <span class="small">Избранное</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-with-icon fw-semibold d-flex flex-column align-items-center py-0 px-2 position-relative" href="@Url.Action("Index", "Cart")" title="Корзина">
                                <i class="bi bi-cart fs-5 mb-1 nav-link-icon"></i>
                                <span class="small">Корзина</span>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger cart-badge" id="cartBadge" style="display: none; font-size: 0.65rem;">0</span>
                            </a>
                        </li>
                        <li class="nav-item d-flex align-items-center ms-1">
                            <form class="d-flex navbar-search-form" method="get" action="@Url.Action("Search", "Product")" role="search">
                                <input class="form-control form-control-sm navbar-search-input" type="search" name="q" placeholder="Найти на AiMarket..." aria-label="Поиск">
                                <button class="btn btn-outline-primary btn-sm ms-1 navbar-search-btn" type="submit" title="Искать">
                                    <i class="bi bi-search"></i>
                                </button>
                            </form>
                        </li>
                    </ul>
                    
                    <ul class="navbar-nav">
                        @{
                            var userJson = Context.Session.GetString("User");
                            var user = userJson != null ? System.Text.Json.JsonSerializer.Deserialize<SimpleEcommerce.Models.User>(userJson) : null;
                            if (user != null)
                            {
                                <li class="nav-item me-3 d-flex align-items-center">
                                    <a href="@Url.Action("Profile", "Account", new { openTopUp = "1" })" class="balance-display d-flex align-items-center gap-2 px-3 py-2 text-decoration-none" title="Пополнить баланс">
                                        <i class="bi bi-wallet2"></i>
                                        <span class="fw-bold">@user.Balance.ToString("N0") ₽</span>
                                    </a>
                                </li>
                                @if (user.Email == "admin@admin.com")
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-warning fw-semibold" href="@Url.Action("Index", "Admin")">
                                            <i class="bi bi-shield-check me-1"></i>Админ-панель
                                        </a>
                                    </li>
                                }
                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="@Url.Action("Profile", "Account")">
                                        <i class="bi bi-person-circle me-1"></i> @user.FirstName
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-danger" href="@Url.Action("Logout", "Account")">
                                        Выйти
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary fw-semibold" href="@Url.Action("Login", "Account")">
                                        <i class="bi bi-box-arrow-in-right me-1"></i> Войти
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main" class="pb-5">
        @RenderBody()
    </main>

    <footer class="footer bg-dark text-white mt-5">
        <div class="footer-partners py-3">
            <div class="container">
                <div class="footer-partners-row d-flex flex-wrap align-items-center justify-content-center gap-2 gap-md-3">
                    <span class="footer-partners-label text-muted small me-1 me-md-2"></span>
                    <span class="footer-partner footer-partner-ozon">Ozon</span>
                    <span class="footer-partner footer-partner-wb">Wildberries</span>
                    <span class="footer-partner footer-partner-yandex">Яндекс Маркет</span>
                    <span class="footer-partner footer-partner-ali">AliExpress</span>
                    <span class="footer-partner footer-partner-lamoda">Lamoda</span>
                    <span class="footer-partner footer-partner-beru">СберМегаМаркет</span>
                </div>
            </div>
        </div>
        <div class="container py-4">
            <div class="row">
                <div class="col-md-6">
                    <h5 class="mb-3">AiMarket</h5>
                    <p class="small text-muted">Интернет-магазин товаров</p>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        <button type="button" class="btn btn-outline-light btn-sm" data-bs-toggle="modal" data-bs-target="#supportModal" aria-label="Служба поддержки">
                            <i class="bi bi-headset me-1"></i>Служба поддержки
                        </button>
                        <a href="@Url.Action("Terms", "Account")" class="btn btn-outline-light btn-sm" aria-label="Пользовательское соглашение">
                            <i class="bi bi-file-text me-1"></i>Пользовательское соглашение
                        </a>
                    </div>
                </div>
                <div class="col-md-6 text-end">
                    <p class="small mb-0">&copy; 2026 AiMarket. Все права защищены.</p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Модальное окно: обращение в службу поддержки (только клиент) -->
    <div class="modal fade" id="supportModal" tabindex="-1" aria-labelledby="supportModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="supportModalLabel">
                        <i class="bi bi-headset me-2"></i>Обращение в службу поддержки
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body" id="supportModalBody">
                    <form id="supportForm" novalidate>
                        <div class="mb-3">
                            <label for="supportTopic" class="form-label">Тема</label>
                            <select class="form-select" id="supportTopic" name="topic" required>
                                <option value="">Выберите тему</option>
                                <option value="order">Вопрос по заказу</option>
                                <option value="payment">Оплата и баланс</option>
                                <option value="delivery">Доставка</option>
                                <option value="return">Возврат товара</option>
                                <option value="other">Другое</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="supportName" class="form-label">Ваше имя</label>
                            <input type="text" class="form-control" id="supportName" name="name" placeholder="Иван" required>
                        </div>
                        <div class="mb-3">
                            <label for="supportEmail" class="form-label">Email</label>
                            <input type="email" class="form-control" id="supportEmail" name="email" placeholder="example@mail.ru" required>
                        </div>
                        <div class="mb-0">
                            <label for="supportMessage" class="form-label">Сообщение</label>
                            <textarea class="form-control" id="supportMessage" name="message" rows="4" placeholder="Опишите ваш вопрос или проблему..." required></textarea>
                        </div>
                    </form>
                    <div id="supportSuccess" class="text-center py-4 d-none">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                        <h6 class="mt-3 mb-2">Обращение принято</h6>
                        <p class="text-muted small mb-0">Мы свяжемся с вами в ближайшее время по указанному email.</p>
                    </div>
                </div>
                <div class="modal-footer" id="supportModalFooter">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary" form="supportForm" id="supportSubmitBtn">
                        <i class="bi bi-send me-1"></i>Отправить
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
